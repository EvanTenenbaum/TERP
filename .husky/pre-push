#!/usr/bin/env bash
# TERP pre-push hook — Linear task state validation
# Blocks pushes for tasks that are cancelled or completed in Linear.

CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo '')

# Skip: exempt branches
if [[ "$CURRENT_BRANCH" =~ ^(main|staging|production)$ ]] || \
   [[ "$CURRENT_BRANCH" =~ ^(hotfix|renovate|dependabot)/ ]]; then
  exit 0
fi

# Skip: HOTFIX mode
if [ "${HOTFIX:-}" = '1' ]; then
  exit 0
fi

# Extract task ID from branch name (TER-NNNN pattern)
TASK_ID=$(echo "$CURRENT_BRANCH" | grep -oE 'TER-[0-9]+' | head -1 || true)

# Skip: no task ID in branch name
if [ -z "$TASK_ID" ]; then
  exit 0
fi

# Run context:refresh (best-effort, silent)
(cd "$(git rev-parse --show-toplevel)" && pnpm context:refresh --silent 2>/dev/null || true) &

# Validate task state in Linear
LINEAR_KEY=$(grep 'LINEAR_API_KEY' ~/.codex/.env 2>/dev/null | cut -d= -f2 | tr -d '\r' || true)

if [ -z "$LINEAR_KEY" ]; then
  # No key — skip validation silently
  exit 0
fi

ISSUE_STATE_TYPE=$(curl -s -X POST https://api.linear.app/graphql \
  -H 'Content-Type: application/json' \
  -H "Authorization: $LINEAR_KEY" \
  --max-time 8 \
  -d "{\"query\":\"{issue(id:\\\"${TASK_ID}\\\"){state{type}}}\"}" \
  2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('data',{}).get('issue',{}).get('state',{}).get('type','unknown'))" 2>/dev/null || echo 'unknown')

if [ "$ISSUE_STATE_TYPE" = 'completed' ] || [ "$ISSUE_STATE_TYPE" = 'cancelled' ]; then
  echo ""
  echo "❌ Cannot push: Linear task ${TASK_ID} is ${ISSUE_STATE_TYPE}."
  echo "   If this push is intentional, use: HOTFIX=1 git push"
  echo ""
  exit 1
fi

# Also run any existing pre-push checks from the original file (if applicable)
exit 0
