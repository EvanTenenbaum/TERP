{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ticket_scores"
  ],
  "properties": {
    "ticket_scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ticket",
          "score",
          "verdict",
          "rationale",
          "evidence_refs",
          "upgrade_actions"
        ],
        "properties": {
          "ticket": {
            "type": "string",
            "pattern": "^TER-(109[2-9]|11[0-3][0-9])$"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "verdict": {
            "type": "string",
            "enum": ["meets_bar", "below_95", "blocked"]
          },
          "rationale": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "upgrade_actions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
