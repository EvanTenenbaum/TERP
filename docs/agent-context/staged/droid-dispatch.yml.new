name: Droid Dispatch

# Programmatic Droid dispatch. Complements droid.yml (which is event-driven on @droid mentions).
# Triggers:
#   - workflow_dispatch: manual / CLI (`gh workflow run droid-dispatch.yml -f prompt="..."`)
#   - repository_dispatch: external automation (Linear webhook, PM agent, cron)
#     Example: gh api /repos/EvanTenenbaum/TERP/dispatches -f event_type=droid-task -f 'client_payload[prompt]=...'
#
# Rename this file to `.github/workflows/droid-dispatch.yml` once the Manus GitHub App is granted
# `workflows: write` permission. See docs/agent-context/INFRA_ACCESS.md §6.

on:
  workflow_dispatch:
    inputs:
      prompt:
        description: "Instruction for the droid agent (can be multi-line)"
        required: true
        type: string
      model:
        description: "Model to use"
        required: false
        default: claude-sonnet-4-5-20250929
        type: choice
        options:
          - claude-sonnet-4-5-20250929
          - claude-haiku-4-5-20251001
          - claude-opus-4-7
          - gpt-5.3-codex
      auto_level:
        description: "Autonomy level"
        required: false
        default: high
        type: choice
        options:
          - low
          - medium
          - high
      base_branch:
        description: "Base branch for the PR"
        required: false
        default: main
        type: string
      linear_ticket:
        description: "Optional Linear ticket ID (e.g. TER-1300) for session file + PR link"
        required: false
        type: string
  repository_dispatch:
    types: [droid-task]

concurrency:
  group: ${{ github.workflow }}-${{ github.event.inputs.linear_ticket || github.event.client_payload.linear_ticket || github.run_id }}
  cancel-in-progress: false

jobs:
  droid-dispatch:
    runs-on: ubuntu-latest
    timeout-minutes: 60
    permissions:
      contents: write
      pull-requests: write
      issues: write
      id-token: write
      actions: read
    steps:
      - name: Checkout repository
        uses: actions/checkout@v5
        with:
          fetch-depth: 0
          ref: ${{ github.event.inputs.base_branch || github.event.client_payload.base_branch || 'main' }}

      - name: Resolve inputs
        id: inputs
        run: |
          PROMPT="${{ github.event.inputs.prompt || github.event.client_payload.prompt }}"
          MODEL="${{ github.event.inputs.model || github.event.client_payload.model || 'claude-sonnet-4-5-20250929' }}"
          AUTO="${{ github.event.inputs.auto_level || github.event.client_payload.auto_level || 'high' }}"
          TICKET="${{ github.event.inputs.linear_ticket || github.event.client_payload.linear_ticket || '' }}"
          if [ -z "$PROMPT" ]; then
            echo "::error::prompt is required"; exit 1
          fi
          {
            echo "model=$MODEL"
            echo "auto=$AUTO"
            echo "ticket=$TICKET"
            echo "prompt<<EOF"
            printf '%s\n' "$PROMPT"
            echo "EOF"
          } >> "$GITHUB_OUTPUT"

      - name: Run Droid (coding task)
        uses: Factory-AI/droid-action@v3
        with:
          factory_api_key: ${{ secrets.FACTORY_API_KEY }}
          prompt: ${{ steps.inputs.outputs.prompt }}
          model: ${{ steps.inputs.outputs.model }}
          auto: ${{ steps.inputs.outputs.auto }}

      - name: Post Linear comment (if ticket provided)
        if: steps.inputs.outputs.ticket != ''
        env:
          LINEAR_API_KEY: ${{ secrets.LINEAR_API_KEY }}
          TICKET: ${{ steps.inputs.outputs.ticket }}
          RUN_URL: ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}
        run: |
          if [ -z "$LINEAR_API_KEY" ]; then
            echo "LINEAR_API_KEY not set; skipping Linear comment."; exit 0
          fi
          curl -sS -X POST https://api.linear.app/graphql \
            -H "Authorization: $LINEAR_API_KEY" \
            -H "Content-Type: application/json" \
            -d "$(jq -n --arg t "$TICKET" --arg u "$RUN_URL" '{query:"mutation($t:String!,$u:String!){commentCreate(input:{issueId:$t, body:(\"Droid dispatch run: \" + $u)}){success}}", variables:{t:$t,u:$u}}')" \
            | head -c 500 || true
