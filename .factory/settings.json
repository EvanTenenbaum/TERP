{
  "$comment": "TERP repo-level Factory/Droid settings. Tighter than the user-level ~/.factory/settings.json defaults. User-level sets auto-high; in this repo we pin auto-medium to honor TERP's 'verification over persuasion' policy and the no-push-from-agent-worktree rule. See AGENTS.md, CLAUDE.md, and docs/agent-context/ for authoritative protocol.",
  "model": "claude-opus-4-7",
  "reasoningEffort": "high",
  "autonomyMode": "auto-medium",
  "diffMode": "github",
  "includeCoAuthoredByDroid": true,
  "enableDroidShield": true,
  "commandAllowlist": [
    "pnpm check",
    "pnpm lint",
    "pnpm lint:fix",
    "pnpm test",
    "pnpm test --run",
    "pnpm test --run --no-color",
    "pnpm build",
    "pnpm preview",
    "pnpm typecheck",
    "pnpm agent:prepare",
    "pnpm pm:launch:check",
    "pnpm db:generate",
    "pnpm db:push",
    "git status",
    "git diff",
    "git log",
    "git branch",
    "git show",
    "git fetch",
    "git pull --ff-only",
    "gh pr view",
    "gh pr list",
    "gh pr diff",
    "gh issue view",
    "gh issue list",
    "gh run list",
    "gh run view"
  ],
  "commandDenylist": [
    "git push origin main",
    "git push origin master",
    "git push origin HEAD:main",
    "git push origin HEAD:master",
    "git push --force",
    "git push -f",
    "git push --force-with-lease origin main",
    "git push --force-with-lease origin master",
    "git reset --hard origin/main",
    "git reset --hard origin/master",
    "pnpm publish",
    "npm publish",
    "rm -rf node_modules",
    "rm -rf drizzle",
    "rm -rf docs/agent-context"
  ]
}
