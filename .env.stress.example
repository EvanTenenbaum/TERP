# Stress testing secret contract (placeholders only - never commit real values)
#
# Copy to .env.stress.local and fill from GitHub Environment secrets:
#   Settings -> Environments -> staging -> Environment secrets

STRESS_TARGET_URL=https://terp-staging-yicld.ondigitalocean.app

# Required: one of token or admin email/password pair.
# Recommended: set admin pair and generate STRESS_AUTH_TOKEN at runtime.
STRESS_ADMIN_EMAIL=__SET_IN_GITHUB_STAGING_SECRET__
STRESS_ADMIN_PASSWORD=__SET_IN_GITHUB_STAGING_SECRET__

# Optional: runtime generated value (do not store long-lived token in GitHub).
STRESS_AUTH_TOKEN=

# Required for invariants gate during stress runs.
DATABASE_URL=__SET_IN_GITHUB_STAGING_SECRET__
