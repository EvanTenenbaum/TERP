# Development environment
NODE_ENV=development
DATABASE_URL="postgresql://user:pass@localhost:5432/terp_dev"
AUTH_JWT_SECRET="dev-secret-key-min-32-characters-long-for-testing"
REQUIRE_AUTH=false
ALLOW_DEV_BYPASS=true
DEV_LOGIN_ENABLED=true
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Feature Flags (enable for preview)
FEATURE_ENABLE_MOBILE_UI=true
FEATURE_ENABLE_NEW_DASHBOARD=false
FEATURE_ENABLE_ADVANCED_PRICING=false
